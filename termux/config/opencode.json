{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "default_agent": "build",
  "shell": "/data/data/com.termux/files/usr/bin/bash",
  "autoupdate": true,
  "share": "manual",
  "permissions": {
    "bash": "grant-permanent",
    "read": "grant-permanent",
    "write": "grant-permanent",
    "edit": "grant-permanent",
    "glob": "grant-permanent",
    "grep": "grant-permanent",
    "webfetch": "grant-permanent",
    "websearch": "grant-permanent"
  },
  "agents": {
    "mobile-build": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.7,
      "instructions": "You are a helpful coding assistant optimized for mobile use. Be concise and provide clear code examples."
    }
  }
}
